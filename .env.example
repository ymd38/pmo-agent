# =============================================================
# PMO Agent — 環境変数テンプレート
# コピーして .env を作成し、各値を環境に合わせて変更してください
#   make env   （または cp .env.example .env）
# =============================================================

# ---------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=pmo_proto

# ホスト側に公開するポート（コンテナ内は常に 3306）。
# 既存の MySQL が 3306 を使っているため、競合回避で 3307 を既定にする。
MYSQL_PORT=3307

# ---------------------------------------------------------------
# API サーバー
# ---------------------------------------------------------------

# JWT 署名シークレット（必須・デフォルト値なし）
# 本番では必ず十分にランダムな文字列に変更すること: openssl rand -base64 48
JWT_SECRET=change-me-in-production

# パスワード設定リンク生成に使うフロントの公開URL
APP_BASE_URL=http://localhost:3000

# 認証Cookieの Secure 属性（既定 true）。HTTPのローカル開発でのみ false にする
# ※ docker-compose.yml がローカル用に false を既定指定している
#COOKIE_SECURE=false

# ---------------------------------------------------------------
# フロントエンド（pmo-dashboard）
# ---------------------------------------------------------------

# ブラウザ（クライアント）から API を叩くベースURL
NUXT_PUBLIC_API_BASE=http://localhost:8080

# SSR（コンテナ内）から API を叩くベースURL（compose ネットワーク経由）
NUXT_API_BASE_SERVER=http://api:8080
